# file test_loop.glang: test iterations of glang's 'walk' and 'while' loops

obj x = 0;

walk i = 0 through 10 {
    x = i;
}

assert_eq(x, 9);

obj y = [1, 2, 3];

walk i through 10 {
    x = i;
}

assert_eq(x, 3);

obj y = 0;

while y != 10 {
    y = y + 1;
}

assert_eq(y, 10);

bark("test_loop.glang: Successful");
