# file test_scope.glang: test glang's scope in function definitions

func import() {
    fetch std_math;
}

import();

try {
    math_pi # can't access this, it's in import()
} catch _ {}

obj x = 10;

func modify() {
    x = 20; # copy of x, only available to modify
}

modify();

assert_eq(x, 10);

bark("test_scope.glang: Successful");
