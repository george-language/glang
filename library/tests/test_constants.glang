# file test_constants.glang: test glang's constant values

# test assigning and changing of constant's values
obj x = 10;
stay y = x;

x = 20;

assert_eq(y, 10); # y should remain 10 because it copied the value of x

# test assigning variables value as constants
stay CONST = [1, 2, 3];
obj variable = CONST;

push(variable, 4); # this can happen, because variables copy the values of constants

assert_eq(CONST, [1, 2, 3]); # should remain [1, 2, 3]

bark("test_constants.glang: Successful");
